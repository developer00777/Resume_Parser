# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Core ─────────────────────────────────────────────────────────────────────
API_KEY=changeme
MAX_FILE_SIZE=10485760
LOG_LEVEL=INFO

# ── Salesforce Connected App credentials ─────────────────────────────────────
# Create a Connected App in Salesforce Setup → App Manager
# Enable OAuth, add scopes: api, refresh_token (or full)
SF_CLIENT_ID=your_consumer_key_here
SF_CLIENT_SECRET=your_consumer_secret_here

# Only needed for Username-Password OAuth flow (leave blank for client_credentials)
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=          # Append to password for non-trusted IPs

SF_LOGIN_URL=https://login.salesforce.com   # or https://test.salesforce.com for sandbox
SF_API_VERSION=59.0
